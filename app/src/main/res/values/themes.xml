<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.BlueBridge" parent="android:Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:statusBarColor">#0F0F1E</item>
        <item name="android:navigationBarColor">#0F0F1E</item>
    </style>

    <style name="Theme.BlueBridge.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#0F0F1E</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/bluebridge_splash_icon</item>
        <item name="postSplashScreenTheme">@style/Theme.BlueBridge</item>
    </style>
</resources>
