<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_dashboard_background"
    android:padding="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_vehicle_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="BlueBridge"
            android:textColor="#F0F4FA"
            android:textSize="15sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_lock_status"
            android:layout_width="wrap_content"
            android:layout_height="24dp"
            android:background="@drawable/widget_battery_panel_background"
            android:gravity="center"
            android:paddingStart="9dp"
            android:paddingEnd="9dp"
            android:text="—"
            android:textColor="#FFFFA726"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_battery_panel"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:background="@drawable/widget_battery_panel_background"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_battery"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Battery —"
                android:textColor="#FFFFFF"
                android:textSize="30sp"
                android:textStyle="bold"
                android:maxLines="1" />

            <TextView
                android:id="@+id/widget_range"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Range —"
                android:textColor="#D0D6E0"
                android:textSize="13sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/widget_battery_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="9dp"
            android:layout_marginTop="7dp"
            android:indeterminate="true"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/widget_battery_progress" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="bottom|center_vertical"
            android:layout_marginTop="6dp">

            <TextView
                android:id="@+id/widget_charging"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Tap to open app"
                android:textColor="#FF35F2B6"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:id="@+id/widget_refresh_button"
                android:layout_width="68dp"
                android:layout_height="30dp"
                android:background="@drawable/widget_action_background"
                android:gravity="center"
                android:text="Refresh"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/widget_updated"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:text="" />
</LinearLayout>
