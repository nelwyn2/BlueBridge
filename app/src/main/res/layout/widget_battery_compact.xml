<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@drawable/widget_dashboard_background"
    android:padding="6dp"
    android:gravity="center_vertical">

    <LinearLayout
        android:id="@+id/widget_battery_panel"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="@drawable/widget_battery_panel_background"
        android:padding="7dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_vehicle_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="BlueBridge"
            android:textColor="#F0F4FA"
            android:textSize="10sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_battery"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="—"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold"
                android:maxLines="1" />

            <TextView
                android:id="@+id/widget_range"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="— mi"
                android:textColor="#BFD0D6E0"
                android:textSize="10sp"
                android:textStyle="bold"
                android:maxLines="1" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/widget_battery_progress"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:layout_marginTop="1dp"
            android:indeterminate="true"
            android:max="100"
            android:progress="0"
            android:progressDrawable="@drawable/widget_battery_progress" />

        <TextView
            android:id="@+id/widget_updated"
            android:layout_width="1dp"
            android:layout_height="1dp"
            android:text="" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_refresh_button"
        android:layout_width="30dp"
        android:layout_height="match_parent"
        android:layout_marginStart="6dp"
        android:background="@drawable/widget_action_background"
        android:gravity="center"
        android:text="↻"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold" />
</LinearLayout>
